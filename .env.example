# ── Why .env.local vs .env? ─────────────────────────────────────────────
# Next.js loads multiple files and merges them (see Next.js "Environment Variables").
# Later files override earlier ones. Typical order includes `.env`, `.env.local`, etc.
# `.env.local` is the usual place for secrets on your machine (often gitignored).
# You can use a single `.env` file instead if you prefer — this repo gitignores both
# `.env` and `.env.local` so neither is committed. Copy this file to `.env` OR `.env.local`.

# Neon PostgreSQL (pooler URL; drop channel_binding if Prisma CLI complains)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Prisma CLI does not load .env.local by itself. This repo uses `npm run db:push` / `db:seed`,
# which load .env.local via dotenv-cli. Or put DATABASE_URL in `.env` and run `npx prisma db push`.

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-string"

# OAuth callback base (same host/port/protocol as in the browser). Lowers redirect_uri_mismatch:
# if unset, Google sees whatever Host the request used (localhost vs 127.0.0.1 vs wrong port).
AUTH_URL="http://localhost:3000"
# Same origin as AUTH_URL (NextAuth client still reads NEXTAUTH_URL in some paths).
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — required for student "Continue with Google"
#
# Setup (once per Google Cloud project):
#   1. https://console.cloud.google.com/apis/credentials
#   2. Configure OAuth consent screen (External + test users if in Testing)
#   3. Create credentials → OAuth client ID → Application type: Web application
#   4. Authorized redirect URIs → must match AUTH_URL + /api/auth/callback/google, e.g.
#      http://localhost:3000/api/auth/callback/google
#      If you open the app via your LAN IP (e.g. http://192.168.x.x:3000), set AUTH_URL and
#      NEXTAUTH_URL to that origin and add the same callback URL here (Google requires an exact match).
#      Production: https://yourdomain.com/api/auth/callback/google
#   5. Paste Client ID and Client secret here, copy to .env.local, restart `npm run dev`
#   6. If you still see redirect_uri_mismatch: while `npm run dev` is running, open
#      http://localhost:3000/api/debug/oauth-redirect — copy addExactlyThisToGoogleAuthorizedRedirectUris
#      into the OAuth client that matches AUTH_GOOGLE_ID (not a different client).
#   7. “You do not have permission to sign in” from Google: OAuth consent screen is usually in “Testing”.
#      Open APIs & Services → OAuth consent screen → Test users → add each @usa.edu.ph account that
#      should be allowed (or publish the app / move to Production when appropriate).
#
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"

# Resend (optional) — welcome email with temporary password after first Google sign-up
# Without RESEND_API_KEY, the dev server logs the temp password to the terminal instead.
# RESEND_API_KEY="re_xxxxxxxx"
# RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Neon Auth (optional) — Neon Console → Branch → Auth
NEON_AUTH_BASE_URL="https://YOUR-ENDPOINT.neonauth.REGION.aws.neon.tech/neondb/auth"
NEON_AUTH_COOKIE_SECRET="at-least-32-characters-random-string"
NEON_AUTH_JWKS_URL="https://YOUR-ENDPOINT.neonauth.REGION.aws.neon.tech/neondb/auth/.well-known/jwks.json"
NEON_DATA_API_URL="https://YOUR-ENDPOINT.apirest.REGION.aws.neon.tech/neondb/rest/v1"
