generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum AppointmentStatus {
  pending
  approved
  rejected
  cancelled
  no_show
  completed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role
  studentId    String?  @unique
  /// Null for Google-only accounts until they set a password (optional feature).
  passwordHash String?
  /// True after Google sign-up until the student sets their own password in profile (no current password required).
  needsInitialPasswordSetup Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile    StudentProfile?
  bmiRecords BmiRecord[]
}

model StudentProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthday            String
  gender              String
  symptomsOrCondition String
  contactNumber       String
  schoolIdNumber      String
  address             String   @default("")
  birthdayEdited      Boolean  @default(false)
  genderEdited        Boolean  @default(false)
}

model BmiRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg  Float
  heightM   Float
  bmi       Float
  category  String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Appointment {
  id                Int               @id @default(autoincrement())
  status            AppointmentStatus @default(pending)
  adminNote         String            @default("")
  submittedAt       DateTime          @default(now())
  reviewedAt        DateTime?
  studentName       String
  email             String
  address           String
  reason            String
  otherReasonDetail String            @default("")
  preferredDate     String
  preferredTime     String
  schoolIdNumber    String?
}

model ClinicWeeklyHours {
  id         Int      @id @default(autoincrement())
  orderIndex Int
  label      String
  hours      String
  updatedAt  DateTime @updatedAt

  @@unique([orderIndex])
}

model ClinicAppointmentSchedule {
  id            Int      @id @default(1)
  slotCapacity  Int      @default(10)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  timeSlots               ClinicAppointmentTimeSlot[]
  blockedDates            ClinicAppointmentBlockedDate[]
  dateOverrides           ClinicAppointmentDateOverride[]
  disabledSlots           ClinicAppointmentDisabledSlot[]
  slotCapacityByDateTime  ClinicAppointmentSlotCapacityOverride[]
}

model ClinicAppointmentTimeSlot {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  orderIndex Int
  time       String

  schedule ClinicAppointmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, orderIndex])
  @@unique([scheduleId, time])
}

model ClinicAppointmentBlockedDate {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  date       String

  schedule ClinicAppointmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
}

model ClinicAppointmentDateOverride {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  date       String
  available  Boolean

  schedule ClinicAppointmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
}

model ClinicAppointmentDisabledSlot {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  date       String
  time       String

  schedule ClinicAppointmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date, time])
}

model ClinicAppointmentSlotCapacityOverride {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  date       String
  time       String
  capacity   Int

  schedule ClinicAppointmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date, time])
}

model VisitorLog {
  id         Int      @id @default(autoincrement())
  reference  String?  @unique
  name       String
  email      String
  department String
  course     String
  year       String
  time       String
  purpose    String
  loggedAt   DateTime @default(now())
}

model PasswordResetOtp {
  id                String   @id @default(cuid())
  email             String
  codeHash          String
  expiresAt         DateTime
  resendAvailableAt DateTime
  consumedAt        DateTime?
  createdAt         DateTime @default(now())

  @@index([email, createdAt])
}

model MedicineRequest {
  id          Int      @id @default(autoincrement())
  studentId   String
  name        String
  medication  String
  quantity    Int      @default(1)
  requestedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([medication])
  @@index([requestedAt])
  @@index([studentId])
}

model BroadcastNotification {
  id                 String   @id
  title              String
  message            String
  createdAt          DateTime @default(now())
  attachmentName     String?
  attachmentMimeType String?
  /// Base64-encoded attachment data stored in the database for serverless compatibility.
  attachmentData     String?

  @@index([createdAt])
}
